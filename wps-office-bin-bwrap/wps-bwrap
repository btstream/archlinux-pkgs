#!/bin/bash

# 检查依赖
for cmd in bwrap xdg-user-dir realpath; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "错误: 未找到依赖命令 $cmd，请先安装。" >&2
        exit 1
    fi
done

# 环境变量适配 (尊重已有设置，默认回退到 fcitx)
export QT_IM_MODULE=${QT_IM_MODULE:-fcitx}
export XMODIFIERS=${XMODIFIERS:-@im=fcitx}
export GTK_IM_MODULE=${GTK_IM_MODULE:-fcitx}

# 基础路径配置
BINDS_LIST="$HOME/.config/wps-bwrap/binds.list"
EXE_NAME=$(basename "$0")
# 如果通过 wps-bwrap 直接运行而非符号链接，默认启动 wps
[[ "$EXE_NAME" == "wps-bwrap" ]] && EXE_NAME="wps"
WPS_BIN="/opt/kingsoft/wps-office/office6/bin/$EXE_NAME"
if [[ ! -x "$WPS_BIN" ]]; then
    echo "错误: 未找到可执行文件 $WPS_BIN" >&2
    exit 1
fi

binds=()

add_bind() {
    local src="$1"
    local dst="${2:-$1}"
    for ((i = 0; i < ${#binds[@]}; i += 3)); do
        if [[ "${binds[i]}" == "--bind" && "${binds[i + 1]}" == "$src" && "${binds[i + 2]}" == "$dst" ]]; then
            return
        fi
    done
    binds+=(--bind "$src" "$dst")
}

decode_file_uri() {
    local uri="$1"
    local path="${uri#file://}"
    if [[ "$path" == localhost/* ]]; then
        path="/${path#localhost/}"
    elif [[ "$path" != /* ]]; then
        path="/$path"
    fi
    printf '%b' "${path//%/\\x}"
}

# 1. 配置文件绑定 (仅在主机存在时绑定)
for dir in fontconfig gtk-2.0 gtk-3.0 gtk-4.0 kingsoft Kingsoft; do
    if [[ -d "$HOME/.config/$dir" ]]; then
        add_bind "$HOME/.config/$dir" "$HOME/.config/$dir"
    fi
done

# 2. 常用配置文件及数据持久化
[[ -f "$HOME/.config/mimeapps.list" ]] && add_bind "$HOME/.config/mimeapps.list" "$HOME/.config/mimeapps.list"
mkdir -p "$HOME/.local/share/Kingsoft"
add_bind "$HOME/.local/share/Kingsoft" "$HOME/.local/share/Kingsoft"

# 3. XDG 用户目录绑定 (自动获取最新路径)
home_path=$(realpath "$HOME")
for xdg_dir in DOCUMENTS DOWNLOAD PICTURES DESKTOP; do
    path=$(xdg-user-dir "$xdg_dir" 2>/dev/null || true)
    [[ -z "$path" || ! -d "$path" ]] && continue
    resolved_path=$(realpath "$path")
    [[ "$resolved_path" == "$home_path" ]] && continue
    add_bind "$resolved_path" "$resolved_path"
done

# 4. 处理用户自定义绑定列表 (支持空格、跳过注释)
if [[ -f "$BINDS_LIST" ]]; then
    while IFS= read -r p || [[ -n "$p" ]]; do
        [[ "$p" =~ ^#.*$ ]] || [[ -z "$p" ]] && continue
        [[ -e "$p" ]] && add_bind "$p" "$p"
    done < "$BINDS_LIST"
fi

# 5. 处理命令行参数 (绑定待打开的文件路径)
processed_args=()
for arg in "$@"; do
    # 移除 file:// 前缀
    clean_path="$arg"
    [[ "$arg" == file://* ]] && clean_path=$(decode_file_uri "$arg")
    # 如果是存在的文件路径，则进行实名绑定
    if [[ -e "$clean_path" ]]; then
        abs_path=$(realpath "$clean_path")
        if [[ -f "$abs_path" ]]; then
            abs_dir=$(dirname "$abs_path")
            add_bind "$abs_dir" "$abs_dir"
        else
            add_bind "$abs_path" "$abs_path"
        fi
        processed_args+=("$abs_path")
    else
        processed_args+=("$arg")
    fi
done

# 6. 执行沙盒
# --unshare-all: 隔离除网络外的所有命名空间
# --dev-bind /dev/dri: 启用显卡硬件加速
exec bwrap --unshare-all --share-net --die-with-parent \
    --ro-bind / / \
    --tmpfs /sys \
    --tmpfs /home \
    --tmpfs /tmp \
    --tmpfs /run \
    --proc /proc \
    --dev /dev \
    --dev-bind-try /dev/dri /dev/dri \
    --ro-bind-try "$XDG_RUNTIME_DIR" "$XDG_RUNTIME_DIR" \
    --ro-bind-try /tmp/.X11-unix /tmp/.X11-unix \
    --setenv XDG_RUNTIME_DIR "$XDG_RUNTIME_DIR" \
    "${binds[@]}" \
    "$WPS_BIN" "${processed_args[@]}"
