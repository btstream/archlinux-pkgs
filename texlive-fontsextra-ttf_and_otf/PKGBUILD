# Maintainer: btstream <btstream@gmail.com>
pkgname=('ttf-texlive-fontsextra' 'otf-texlive-fontsextra')
pkgbase="texlive-fontsextra"
pkgver=2026.0
pkgrel=1
_pkgrel=3
# epoch=
pkgdesc="TrueType and OpenType fonts from texlive"
arch=("any")
url=""
license=('GPL')
# depends=()
# makedepends=()
# checkdepends=()
# optdepends=()
# provides=()
conflicts=("texlive-fontsextra")
# replaces=()
# backup=()
# options=()
# install=
# changelog=
source=("https://mirrors.ustc.edu.cn/archlinux/extra/os/x86_64/${pkgbase}-${pkgver}-${_pkgrel}-any.pkg.tar.zst")
noextract=()
sha256sums=('bae6ca1c5a60b96e86dc5d47d5808d74ab91fb14a661d384ae833c5d48c71045')

package_ttf-texlive-fontsextra() {
    pkgdesc="TrueType fonts from texlive"
    install -dm755 "${pkgdir}/usr/share/fonts/texlive-fontsextra/"
    cp -r "${srcdir}/usr/share/texmf-dist/fonts/truetype" "${pkgdir}/usr/share/fonts/texlive-fontsextra/"
}

package_otf-texlive-fontsextra() {
    pkgdesc="OpenType fonts from texlive"
    install -dm755 "${pkgdir}/usr/share/fonts/texlive-fontsextra/"
    cp -r "${srcdir}/usr/share/texmf-dist/fonts/opentype" "${pkgdir}/usr/share/fonts/texlive-fontsextra/"
}
